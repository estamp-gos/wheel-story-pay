SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_16_char_app_password_no_spaces
NOTIFY_EMAIL=your@gmail.com
PORT=3000

# On Vercel: Project → Settings → Environment Variables
# Add SMTP_USER, SMTP_PASS, NOTIFY_EMAIL (and optional SMTP_HOST / SMTP_PORT)
# Then Redeploy. Do not commit .env.
